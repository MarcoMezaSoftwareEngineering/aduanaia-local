# Copiar a .env y ajustar valores reales.
# AduanaIA Local — configuración del MVP (Fases 1–2).

# --- PostgreSQL ---
DATABASE_URL=postgresql+psycopg://aduanaia:aduanaia@localhost:5432/aduanaia

# --- Ollama (LLM local en GPU) ---
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=qwen3:8b
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_MAX_TOKENS=1500
LLM_CONTEXT_TOKENS=8192

# --- Embeddings BGE-M3 (GPU vía sentence-transformers) ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIM=1024

# --- Milvus Standalone (Docker, ver docker-compose.yml) ---
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=aduana_normativa_chunks

# --- Parámetros RAG (§20 del documento técnico) ---
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=12
RAG_TOP_K_FINAL=5
RAG_MIN_SCORE=0.55

# --- Rutas locales ---
DOCS_BASE_PATH=./docs
UPLOAD_PATH=./docs/uploaded
PROCESSED_PATH=./data/processed
REPORTS_PATH=./reports

# --- OCR (Tesseract) ---
# Ajustar a la ruta real de instalación en Windows si no está en PATH.
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_LANG=spa+eng

# --- Logging ---
LOG_LEVEL=INFO
